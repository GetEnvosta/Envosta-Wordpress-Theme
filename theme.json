{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "slug": "primary",       "color": "#0d2e1c",  "name": "Primary" },
        { "slug": "primary-light", "color": "#1a5c38",  "name": "Primary Light" },
        { "slug": "cta",           "color": "#1a6b3a",  "name": "CTA" },
        { "slug": "cta-hover",     "color": "#145a30",  "name": "CTA Hover" },
        { "slug": "bg",            "color": "#ffffff",  "name": "Background" },
        { "slug": "bg-soft",       "color": "#f8f8f6",  "name": "Background Soft" },
        { "slug": "bg-dark",       "color": "#111111",  "name": "Background Dark" },
        { "slug": "text",          "color": "#1a1a1a",  "name": "Text" },
        { "slug": "text-muted",    "color": "#6b6b6b",  "name": "Text Muted" },
        { "slug": "text-light",    "color": "#ffffff",  "name": "Text Light" },
        { "slug": "border",        "color": "#e5e5e5",  "name": "Border" }
      ]
    },
    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Playfair Display, Georgia, serif",
          "fontFace": [
            {
              "fontFamily": "Playfair Display",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "src": ["https://fonts.gstatic.com/s/playfairdisplay/v37/nuFiD-vYSZviVYUb_rj3ij__anPXBYf9lW4e_bXN.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "DM Sans, -apple-system, BlinkMacSystemFont, sans-serif",
          "fontFace": [
            {
              "fontFamily": "DM Sans",
              "fontWeight": "400 500 600",
              "fontStyle": "normal",
              "src": ["https://fonts.gstatic.com/s/dmsans/v15/rP2Hp2ywxg089UriCZa4ET-DNl0.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",                    "name": "XS" },
        { "slug": "sm",   "size": "0.875rem",                   "name": "SM" },
        { "slug": "base", "size": "1rem",                       "name": "Base" },
        { "slug": "lg",   "size": "1.125rem",                   "name": "LG" },
        { "slug": "xl",   "size": "1.25rem",                    "name": "XL" },
        { "slug": "2xl",  "size": "1.5rem",                     "name": "2XL" },
        { "slug": "3xl",  "size": "2rem",                       "name": "3XL" },
        { "slug": "4xl",  "size": "2.75rem",                    "name": "4XL" },
        { "slug": "5xl",  "size": "3.75rem",                    "name": "5XL" },
        { "slug": "hero", "size": "clamp(2.5rem, 6vw, 5rem)",   "name": "Hero" }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "defaultSpacingSizes": false,
      "units": ["px", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        { "slug": "1",  "size": "0.25rem", "name": "1" },
        { "slug": "2",  "size": "0.5rem",  "name": "2" },
        { "slug": "3",  "size": "0.75rem", "name": "3" },
        { "slug": "4",  "size": "1rem",    "name": "4" },
        { "slug": "6",  "size": "1.5rem",  "name": "6" },
        { "slug": "8",  "size": "2rem",    "name": "8" },
        { "slug": "12", "size": "3rem",    "name": "12" },
        { "slug": "16", "size": "4rem",    "name": "16" },
        { "slug": "24", "size": "6rem",    "name": "24" },
        { "slug": "32", "size": "8rem",    "name": "32" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "border": {
      "radius": true,
      "color": true,
      "style": true,
      "width": true
    },
    "blocks": {
      "core/button": {
        "color": { "custom": false }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "lineHeight": "1.15"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--hero)",
          "fontWeight": "700"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "fontWeight": "700"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "fontWeight": "600"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--cta)",
          "text": "var(--wp--preset--color--text-light)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--base)"
        },
        "border": {
          "radius": "9999px"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--cta-hover)"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    }
  }
}
