{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "slug": "base",         "color": "#ffffff",  "name": "Base" },
        { "slug": "base-soft",    "color": "#f8f8f6",  "name": "Base Soft" },
        { "slug": "contrast",     "color": "#111111",  "name": "Contrast" },
        { "slug": "accent",       "color": "#1a6b3a",  "name": "Accent" },
        { "slug": "accent-hover", "color": "#145a30",  "name": "Accent Hover" }
      ]
    },
    "typography": {
      "fluid": true,
      "customFontSize": false,
      "defaultFontSizes": false,
      "writingMode": true,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Playfair Display, Georgia, serif",
          "fontFace": [
            {
              "fontFamily": "Playfair Display",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "src": ["file:./assets/fonts/PlayfairDisplay-Variable.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "DM Sans, -apple-system, BlinkMacSystemFont, sans-serif",
          "fontFace": [
            {
              "fontFamily": "DM Sans",
              "fontWeight": "400 600",
              "fontStyle": "normal",
              "src": ["file:./assets/fonts/DMSans-Variable.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small",    "size": "0.875rem",                    "name": "Small" },
        { "slug": "medium",   "size": "1rem",                        "name": "Medium" },
        { "slug": "large",    "size": "1.5rem",                      "name": "Large",   "fluid": { "min": "1.25rem",  "max": "1.5rem" } },
        { "slug": "x-large",  "size": "2.75rem",                     "name": "X-Large", "fluid": { "min": "2rem",     "max": "2.75rem" } },
        { "slug": "xx-large", "size": "clamp(2.5rem, 6vw, 5rem)",    "name": "XX-Large" }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "defaultSpacingSizes": false,
      "units": ["px", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        { "slug": "10", "size": "0.25rem", "name": "1" },
        { "slug": "20", "size": "0.5rem",  "name": "2" },
        { "slug": "30", "size": "1rem",    "name": "3" },
        { "slug": "40", "size": "1.5rem",  "name": "4" },
        { "slug": "50", "size": "2rem",    "name": "5" },
        { "slug": "60", "size": "4rem",    "name": "6" },
        { "slug": "70", "size": "6rem",    "name": "7" },
        { "slug": "80", "size": "8rem",    "name": "8" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "border": {
      "radius": true,
      "color": true,
      "style": true,
      "width": true
    },
    "blocks": {
      "core/button": {
        "color": { "custom": false }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "spacing": {
      "blockGap": "1.2rem",
      "padding": {
        "left": "var(--wp--preset--spacing--50)",
        "right": "var(--wp--preset--spacing--50)"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.15"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--base)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--medium)"
        },
        "border": {
          "radius": "9999px"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--50)",
            "right": "var(--wp--preset--spacing--50)"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--accent-hover)"
          }
        }
      },
      "link": {
        "color": {
          "text": "currentColor"
        }
      }
    },
    "blocks": {
      "core/separator": {
        "color": {
          "text": "color-mix(in srgb, currentColor 25%, transparent)"
        },
        "border": {
          "color": "currentColor",
          "width": "1px 0 0 0",
          "style": "solid"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "500"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "700"
        },
        "elements": {
          "link": {
            "color": {
              "text": "currentColor"
            },
            ":hover": {
              "color": {
                "text": "var(--wp--preset--color--accent)"
              }
            }
          }
        }
      },
      "woocommerce/checkout": {
        "color": {
          "background": "var(--wp--preset--color--base)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)"
        }
      },
      "woocommerce/cart": {
        "color": {
          "background": "var(--wp--preset--color--base)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
