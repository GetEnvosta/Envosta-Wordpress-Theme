{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "envosta/menu-drawer",
	"version": "1.0.0",
	"title": "Menu Drawer",
	"category": "design",
	"description": "A trigger button that slides open an editable drawer template part. Mirrors the WooCommerce Mini-Cart pattern — drop the block into a header, pick an icon, and the drawer content lives in the Menu Drawer template part.",
	"keywords": [ "menu", "drawer", "hamburger", "navigation", "mobile" ],
	"icon": "menu-alt",
	"supports": {
		"html": false,
		"align": false,
		"interactivity": true,
		"color": {
			"text": true,
			"background": false,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": false
		}
	},
	"attributes": {
		"triggerIcon": {
			"type": "string",
			"enum": [ "hamburger", "menu", "dots", "dots-vertical", "grid", "list", "chevron-down" ],
			"default": "hamburger"
		},
		"triggerLabel": {
			"type": "string",
			"default": ""
		},
		"iconSize": {
			"type": "number",
			"default": 24
		}
	},
	"textdomain": "envosta",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"editorScriptModule": "file:./edit.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
