{
  "version": 3,
  "title": "Section - Primary",
  "slug": "section-4",
  "blockTypes": ["core/group", "core/columns", "core/column"],
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--primary, var(--wp--preset--color--contrast))",
      "text": "var(--wp--preset--color--base)"
    },
    "elements": {
      "heading": { "color": { "text": "var(--wp--preset--color--base)" } },
      "link": { "color": { "text": "currentColor" } },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--base)"
        },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--accent-hover)" }
        }
      }
    },
    "blocks": {
      "core/separator": {
        "color": { "text": "color-mix(in srgb, currentColor 25%, transparent)" }
      }
    }
  }
}
