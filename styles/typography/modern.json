{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Modern",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"slug": "heading",
					"name": "Heading",
					"fontFamily": "'Fraunces', Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"src": [ "https://fonts.gstatic.com/s/fraunces/v35/6NUh8FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0K7iNouAlDFg.woff2" ]
						}
					]
				},
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"src": [ "https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2" ]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"lineHeight": "1.65"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "500",
					"letterSpacing": "-0.025em",
					"lineHeight": "1.02"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "500",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "500"
				}
			}
		}
	}
}
