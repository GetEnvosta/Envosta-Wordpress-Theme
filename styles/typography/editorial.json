{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Editorial",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"slug": "heading",
					"name": "Heading",
					"fontFamily": "'Playfair Display', Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "400 900",
							"fontStyle": "normal",
							"src": [ "https://fonts.gstatic.com/s/playfairdisplay/v37/nuFiD-vYSZviVYUb_rj3ij__anPXBYf9lW4e_bXN.woff2" ]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "400 900",
							"fontStyle": "italic",
							"src": [ "https://fonts.gstatic.com/s/playfairdisplay/v37/nuFkD-vYSZviVYUb_rj3ij__anPXBYX_lKkyVjxbBbB4.woff2" ]
						}
					]
				},
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "'Libre Franklin', -apple-system, BlinkMacSystemFont, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Libre Franklin",
							"fontWeight": "300 700",
							"fontStyle": "normal",
							"src": [ "https://fonts.gstatic.com/s/librefranklin/v17/jizOREVItHgc8qDIbSTKq4XkRiUF2A.woff2" ]
						}
					]
				},
				{
					"slug": "serif",
					"name": "Body Serif",
					"fontFamily": "Lora, Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Lora",
							"fontWeight": "400 700",
							"fontStyle": "normal",
							"src": [ "https://fonts.gstatic.com/s/lora/v35/0QI6MX1D_JOuGQbT0gvTJPa787weuxJMkq18.woff2" ]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--serif)",
			"lineHeight": "1.75"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "900",
					"letterSpacing": "-0.02em",
					"lineHeight": "0.98"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "800",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase",
					"fontSize": "0.75rem",
					"fontWeight": "700"
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase",
					"fontSize": "0.72rem",
					"fontWeight": "700"
				}
			}
		}
	}
}
