{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Envosta Site Config",
  "description": "Configuration schema for Envosta WordPress themes. Generated by the Envosta skill, uploaded via the Envosta plugin, stored as the 'envosta_site_config' WP option.",
  "type": "object",
  "properties": {
    "business": {
      "type": "object",
      "description": "Client business information",
      "properties": {
        "name": { "type": "string", "description": "Business name" },
        "tagline": { "type": "string", "description": "Short tagline or slogan" },
        "phone": { "type": "string", "description": "Business phone number" },
        "email": { "type": "string", "format": "email", "description": "Business email" },
        "address": { "type": "string", "description": "Street address" },
        "city": { "type": "string", "description": "City" },
        "region": { "type": "string", "description": "Province or state" },
        "industry": { "type": "string", "description": "Industry category (used for default color presets)" }
      },
      "required": ["name"]
    },
    "colors": {
      "type": "object",
      "description": "Client brand colors — overrides theme.json palette via wp_theme_json_data_theme filter in the plugin",
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "Primary brand color (headings, dark sections)" },
        "primary-light": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "Lighter variant of primary (hover states)" },
        "cta": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "CTA button color" },
        "cta-hover": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "CTA button hover color" }
      },
      "required": ["primary", "cta"]
    },
    "content": {
      "type": "object",
      "description": "Per-pattern content. Keys match pattern slugs. Theme falls back to placeholder defaults if a key is missing.",
      "properties": {
        "hero-split": {
          "type": "object",
          "properties": {
            "eyebrow": { "type": "string" },
            "headline": { "type": "string" },
            "description": { "type": "string" },
            "cta_primary": { "type": "string" },
            "cta_secondary": { "type": "string" },
            "image_alt": { "type": "string" }
          }
        },
        "hero-centered": {
          "type": "object",
          "properties": {
            "eyebrow": { "type": "string" },
            "headline": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "services-grid": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "description": { "type": "string" },
            "services": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "icon": { "type": "string", "description": "Emoji or icon character" },
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                },
                "required": ["name", "description"]
              }
            }
          }
        },
        "social-proof": {
          "type": "object",
          "properties": {
            "stats": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "value": { "type": "string", "description": "Stat value (e.g. '100+', '5★')" },
                  "label": { "type": "string", "description": "Stat label (e.g. 'Projects Completed')" }
                },
                "required": ["value", "label"]
              }
            }
          }
        },
        "differentiator": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "description": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of differentiator bullet points"
            },
            "image_alt": { "type": "string" }
          }
        },
        "proof": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "testimonials": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "quote": { "type": "string" },
                  "name": { "type": "string" },
                  "location": { "type": "string" },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 }
                },
                "required": ["quote", "name"]
              }
            }
          }
        },
        "cta-banner": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "description": { "type": "string" },
            "cta_text": { "type": "string" }
          }
        },
        "faq": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "question": { "type": "string" },
                  "answer": { "type": "string" }
                },
                "required": ["question", "answer"]
              }
            }
          }
        },
        "final-cta": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "description": { "type": "string" },
            "cta_text": { "type": "string" }
          }
        }
      }
    },
    "pages": {
      "type": "object",
      "description": "Per-page configuration. Keys are template slugs (e.g. 'front-page', 'about').",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Ordered list of pattern slugs for this page"
          },
          "seo": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "Page title tag" },
              "description": { "type": "string", "description": "Meta description (150-160 chars)" },
              "schema_type": { "type": "string", "description": "Schema.org type (e.g. LocalBusiness, Service, FAQPage)" }
            }
          }
        }
      }
    },
    "seo": {
      "type": "object",
      "description": "Site-wide SEO inputs from the client brief",
      "properties": {
        "primary_keyword": { "type": "string" },
        "location_keyword": { "type": "string" },
        "secondary_keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
